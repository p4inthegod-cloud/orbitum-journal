{
  "cleanUrls": true,
  "functions": {
    "api/ticker.js": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/notify.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/alerts.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/weekly.js": {
      "memory": 256,
      "maxDuration": 25
    },
    "api/ai.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/admin.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/bot.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/webhook-tv.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/report.js": {
      "memory": 256,
      "maxDuration": 25
    },
    "api/daily.js": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/finnhub.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/onboarding.js": {
      "memory": 256,
      "maxDuration": 25
    }
  },
  "rewrites": [
    {
      "source": "/screener",
      "destination": "/screener.html"
    },
    {
      "source": "/journal",
      "destination": "/journal.html"
    },
    {
      "source": "/profile",
      "destination": "/profile.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/pay",
      "destination": "/pay.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/cabinet",
      "destination": "/cabinet.html"
    },
    {
      "source": "/trade-analyzer",
      "destination": "/trade-analyzer.html"
    },
    {
      "source": "/ai-journal",
      "destination": "/ai-journal.html"
    }
  ],
  "headers": [
    {
      "source": "/api/ai",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://orbitum.trade"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type"
        }
      ]
    },
    {
      "source": "/api/admin",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://orbitum.trade"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://orbitum.trade"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, X-Notify-User, X-Cron-Secret"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}