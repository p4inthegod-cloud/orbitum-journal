{
  "functions": {
    "api/ticker.js": { "memory": 256, "maxDuration": 15 },
    "api/notify.js": { "memory": 256, "maxDuration": 10 },
    "api/alerts.js": { "memory": 256, "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/screener", "destination": "/screener.html" },
    { "source": "/journal",  "destination": "/journal.html"  },
    { "source": "/chart",    "destination": "/chart.html"    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
