{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/journal",
      "destination": "/journal.html"
    },
    {
      "source": "/pay",
      "destination": "/pay.html"
    },
    {
      "source": "/screener",
      "destination": "/screener.html"
    },
    {
      "source": "/profile",
      "destination": "/profile.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    }
  ],
  "crons": [
    {
      "path": "/api/alerts",
      "schedule": "*/5 * * * *"
    }
  ]
}