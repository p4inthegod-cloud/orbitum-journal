{
  "version": 2,
  "functions": {
    "api/admin.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/ai.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/bot.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/engage.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/market.js": {
      "memory": 256,
      "maxDuration": 20
    },
    "api/report.js": {
      "memory": 256,
      "maxDuration": 25
    },
    "api/ticker.js": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/webhook-tv.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/daily",
      "destination": "/api/engage?__flow=daily"
    },
    {
      "source": "/api/weekly",
      "destination": "/api/engage?__flow=weekly"
    },
    {
      "source": "/api/notify",
      "destination": "/api/engage?__flow=notify"
    },
    {
      "source": "/api/onboarding",
      "destination": "/api/engage?__flow=onboarding"
    },
    {
      "source": "/api/alerts",
      "destination": "/api/market?__flow=alerts"
    },
    {
      "source": "/api/finnhub",
      "destination": "/api/market?__flow=finnhub"
    },
    {
      "source": "/screener",
      "destination": "/screener.html"
    },
    {
      "source": "/journal",
      "destination": "/journal.html"
    },
    {
      "source": "/profile",
      "destination": "/profile.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/pay",
      "destination": "/pay.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/cabinet",
      "destination": "/cabinet.html"
    },
    {
      "source": "/trade-analyzer",
      "destination": "/trade-analyzer.html"
    },
    {
      "source": "/ai-journal",
      "destination": "/ai-journal.html"
    }
  ],
  "headers": [
    {
      "source": "/api/ai",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type"
        }
      ]
    },
    {
      "source": "/api/admin",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, X-Notify-User, X-Cron-Secret"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}