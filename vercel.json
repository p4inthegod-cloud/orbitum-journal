{
  "functions": {
    "api/ticker.js": { "memory": 256, "maxDuration": 15 },
    "api/notify.js": { "memory": 256, "maxDuration": 10 },
    "api/alerts.js": { "memory": 256, "maxDuration": 10 },
    "api/weekly.js": { "memory": 256, "maxDuration": 25 },
    "api/daily.js":  { "memory": 256, "maxDuration": 15 },
    "api/ai.js":     { "memory": 256, "maxDuration": 30 },
    "api/admin.js":  { "memory": 256, "maxDuration": 10 },
    "api/report.js": { "memory": 256, "maxDuration": 25 }
  },
  "rewrites": [
    { "source": "/screener", "destination": "/screener.html" },
    { "source": "/journal",  "destination": "/journal.html"  },
    { "source": "/profile",  "destination": "/profile.html"  },
    { "source": "/login",    "destination": "/login.html"    },
    { "source": "/pay",      "destination": "/pay.html"      },
    { "source": "/admin",    "destination": "/admin.html"    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, X-Notify-User, X-Cron-Secret" }
      ]
    }
  ]
}
